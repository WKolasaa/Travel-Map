APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/travel_map
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
SESSION_SECRET=change-me-long-random-secret
SESSION_TTL_SECONDS=86400
PASSWORD_SALT=travel-map-salt
MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media
MAX_UPLOAD_BYTES=10485760

# Migrations are applied from backend/migrations on backend startup.
# You can also run them manually with: python run_migrations.py
# The first startup seeds a persisted admin user from ADMIN_EMAIL / ADMIN_PASSWORD / ADMIN_NAME if it does not exist yet.
# Additional managed users are created in the admin UI and can sign in with their own persisted credentials.
